# 复制这个文件为 .env 并填入真实的 API key
# .env 已经被 .gitignore，永远不会被 commit

# ============================
# 第 7 章：LLM Provider
# ============================
DEEPSEEK_API_KEY=sk-你的key
LLM_MODEL_ID=deepseek-chat

# ============================
# 第 8 章：云服务（仅在跑记忆/RAG demo 时需要）
# ============================

# Qdrant Cloud（向量数据库）
# 注册：https://cloud.qdrant.io
QDRANT_URL=https://你的cluster.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=你的qdrant_key
QDRANT_COLLECTION=hello_agents_vectors
QDRANT_VECTOR_SIZE=1024
QDRANT_DISTANCE=cosine

# Neo4j Aura（图数据库）
# 注册：https://console.neo4j.io
NEO4J_URI=neo4j+s://你的instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=你的密码
# ⚠️ Aura Free 的默认 database 名是 instance ID，不是 "neo4j"
# 用 `python diagnose_neo4j.py` 查真实名字，填到这里
NEO4J_DATABASE=你的实例ID

# DashScope（embedding 服务，国际版新加坡端点）
# 注册：https://dashscope.console.aliyun.com  或国际版 https://www.alibabacloud.com
EMBED_MODEL_TYPE=dashscope
EMBED_API_KEY=sk-你的dashscope_key
EMBED_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
